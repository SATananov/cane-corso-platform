# Cane Corso Platform example environment only. Do not put real secrets here.
NODE_ENV=development

# App URLs
APP_URL=http://localhost:3000
NEXT_PUBLIC_APP_URL=http://localhost:3000

# Database provider / Neon-ready PostgreSQL
DATABASE_PROVIDER=neon
DATABASE_URL=postgresql://USER:PASSWORD@ep-example-pooler.eu-central-1.aws.neon.tech/cane_corso_platform?sslmode=require
DATABASE_URL_DIRECT=postgresql://USER:PASSWORD@ep-example.eu-central-1.aws.neon.tech/cane_corso_platform?sslmode=verify-full
DATABASE_SSL=true

# Auth/session
AUTH_SECRET=replace-with-a-long-random-secret-at-least-32-characters
SESSION_COOKIE_NAME=ccp_session

# Storage buckets
STORAGE_BUCKET_DOGS=dogs
STORAGE_BUCKET_CERTIFICATES=certificates
STORAGE_BUCKET_PARTNERS=partners

# Optional development flags
AUTH_PROVIDER=local
ENABLE_DEV_BOOTSTRAP_SESSION=false
