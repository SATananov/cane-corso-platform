# Web app environment template
# Copy to apps/web/.env.local for local web development.
# Do not commit real secrets.

DATABASE_PROVIDER=postgres
DATABASE_URL=postgres://postgres:postgres@localhost:5432/cane_corso_platform
DATABASE_URL_DIRECT=postgres://postgres:postgres@localhost:5432/cane_corso_platform
DATABASE_EXPECTED_NAME=cane_corso_platform
DATABASE_SSL=false

# Production Neon example. Keep real values only in Netlify or local .env.local.
# DATABASE_PROVIDER=neon
# DATABASE_URL=postgresql://user:password@ep-example.eu-central-1.aws.neon.tech/cane_corso_platform?sslmode=verify-full
# DATABASE_URL_DIRECT=postgresql://user:password@ep-example.eu-central-1.aws.neon.tech/cane_corso_platform?sslmode=verify-full
# DATABASE_EXPECTED_NAME=cane_corso_platform
# DATABASE_SSL=true

AUTH_SECRET=replace-with-a-long-random-local-secret
SESSION_COOKIE_NAME=ccp_session
SESSION_ISSUER=cane-corso-platform
SESSION_AUDIENCE=cane-corso-platform-web
NEXT_PUBLIC_APP_URL=http://localhost:3000
NEXT_PUBLIC_GOOGLE_MAPS_API_KEY=
