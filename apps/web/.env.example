# Local PostgreSQL development
DATABASE_PROVIDER=postgres
DATABASE_EXPECTED_NAME=cane_corso_platform
DATABASE_URL=postgres://postgres:postgres@localhost:5432/cane_corso_platform
DATABASE_SSL=false

# Neon DB production/staging example
# DATABASE_PROVIDER=neon
# DATABASE_EXPECTED_NAME=cane_corso_platform
# DATABASE_URL=postgresql://USER:PASSWORD@ep-example-pooler.REGION.aws.neon.tech/cane_corso_platform?sslmode=require
# DATABASE_SSL=true
# Optional alias only if DATABASE_URL is not set:
# NEON_DATABASE_URL=postgresql://USER:PASSWORD@ep-example-pooler.REGION.aws.neon.tech/cane_corso_platform?sslmode=require

# Recommended runtime settings:
APP_URL=http://localhost:3000
NEXT_PUBLIC_APP_URL=http://localhost:3000
AUTH_PROVIDER=custom
AUTH_SECRET=change-me
SESSION_SECRET=change-me
STORAGE_BUCKET_DOGS=dogs
STORAGE_BUCKET_CERTIFICATES=certificates
STORAGE_BUCKET_PARTNERS=partners

# Development only. In production the app now defaults this to false unless you set it explicitly.
ENABLE_DEV_BOOTSTRAP_SESSION=true

# Google Maps / Places client integration
NEXT_PUBLIC_GOOGLE_MAPS_API_KEY=replace-with-restricted-browser-key

# Client base URLs
NEXT_PUBLIC_API_BASE_URL=http://localhost:3000
EXPO_PUBLIC_API_BASE_URL=http://localhost:3000

# Optional local workshop storage overrides
LOCAL_STORAGE_PUBLIC_DIR=apps/web/public/uploads
LOCAL_STORAGE_PUBLIC_BASE_PATH=/uploads
